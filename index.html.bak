    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800&family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        h1, h2, h3 { font-family: 'Montserrat', sans-serif; }
        .bg-navy { background-color: #0A192F; }
        .text-cyan { color: #00D4FF; }
        .bg-cyan { background-color: #00D4FF; }
        .text-gold { color: #FFB800; }
        .bg-gold { background-color: #FFB800; }
        .border-gold { border-color: #FFB800; }
    </style>
</head>
<body class="bg-white text-gray-800">

    <!-- Header -->
    <header class="bg-navy py-4">
        <div class="container mx-auto px-4 flex justify-between items-center">
            <div class="flex items-center">
                <img src="logo_dynamic.png" alt="SolarVelocity AI Logo" class="h-12 mr-3">
